# Database
DATABASE_URL="postgresql://glamping:glamping_secret@localhost:5433/glamping?schema=public"

# JWT
JWT_SECRET="generate-with: node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""
JWT_EXPIRES_IN="15m"
REFRESH_EXPIRES_IN="7d"

# Server
PORT=3000

# CORS - comma-separated list of allowed origins
# Production: "https://exemplehotel.tw1.ru"
# Development: "http://localhost:5173,http://localhost:5174"
FRONTEND_URL="http://localhost:5173,http://localhost:5174"

# Web Push (optional)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@glamping.com"
